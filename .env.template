# ===========================================
# Staffbot Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# For Claude Code web, set these in your project's environment variable settings.

# --- Database Connection ---
DB_TYPE=postgres
DB_HOST=your-database-host.example.com
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_read_only_db_user
DB_PASSWORD=your_database_password

# --- SSH Tunnel (required when the database has IP allowlists) ---
SSH_HOST=your-bastion-host.example.com
SSH_PORT=22
SSH_USER=your_ssh_username

# For local use: path to the SSH private key file
SSH_KEY=~/.ssh/staffbot_key

# For web use: base64-encoded private key (instead of SSH_KEY)
# Generate this value by running: base64 < ~/.ssh/staffbot_key
SSH_PRIVATE_KEY_BASE64=
