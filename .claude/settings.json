{
	"permissions": {
		"allow": ["Read", "Glob", "Grep", "Write", "Edit", "Bash", "Agent"],
		"deny": []
	},
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR\"/scripts/developer-mode-status.sh"
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Write|Edit|Bash|NotebookEdit|Agent",
				"hooks": [
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR\"/scripts/sandbox-write-guard.sh"
					}
				]
			}
		]
	}
}
